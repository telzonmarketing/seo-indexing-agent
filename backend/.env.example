# ═══════════════════════════════════════════════════════════════════════════════
# SEO OS — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Generate SECRET_KEY with: openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=SEO OS
DEBUG=false

# CRITICAL: generate a real secret with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Database ─────────────────────────────────────────────────────────────────
# Docker networking uses service name "postgres". Local dev uses localhost.
DATABASE_URL=postgresql+asyncpg://seo:seopass@postgres:5432/seoos
DATABASE_URL_SYNC=postgresql://seo:seopass@postgres:5432/seoos

# Local dev overrides:
# DATABASE_URL=postgresql+asyncpg://seo:seopass@localhost:5432/seoos
# DATABASE_URL_SYNC=postgresql://seo:seopass@localhost:5432/seoos

# ── Redis / Celery ────────────────────────────────────────────────────────────
# Docker networking uses service name "redis". Local dev uses localhost.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Local dev overrides:
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Qdrant (Vector DB) ────────────────────────────────────────────────────────
# Docker: service name "qdrant". Local dev: localhost.
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Local dev:
# QDRANT_HOST=localhost

# ── Ollama (Local AI) ─────────────────────────────────────────────────────────
# Docker: host.docker.internal (Ollama runs on host, not inside Docker)
# Local dev: localhost
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# RAM guide — pick model based on your VPS size:
# 4GB VPS  → llama3.2:3b
# 8GB VPS  → deepseek-r1:8b     (default)
# 16GB VPS → deepseek-r1:14b
# 32GB VPS → deepseek-r1:32b

# Local dev:
# OLLAMA_HOST=http://localhost:11434

# ── Google OAuth (for GSC / GA4 integration) ──────────────────────────────────
# Get these from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Production: https://api.telzonmarketing.in/api/integrations/google/callback
# Staging:    https://staging.telzonmarketing.in/api/integrations/google/callback
# Local dev:  http://localhost:8000/api/integrations/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/api/integrations/google/callback

# ── Crawler ───────────────────────────────────────────────────────────────────
CRAWLER_MAX_PAGES=500
CRAWLER_DELAY_MS=300
CRAWLER_TIMEOUT_SECONDS=30
CRAWLER_CONCURRENT=5

# ── Client Data Directory ─────────────────────────────────────────────────────
# Where per-client workspaces are stored (crawl data, reports, exports, etc.)
# Docker: /data/seo-os   |   Local dev: /tmp/seo-os   |   VPS: /opt/seoos/data
SEO_OS_DATA_DIR=/data/seo-os

# ── Domain Config ─────────────────────────────────────────────────────────────
# Used for generating absolute URLs in reports/emails
ADMIN_DOMAIN=admin.telzonmarketing.in
API_DOMAIN=api.telzonmarketing.in
MISSION_CONTROL_DOMAIN=missioncontrol.telzonmarketing.in

# ── Optional Integrations ─────────────────────────────────────────────────────
# OpenAI fallback (optional — Ollama is used by default)
OPENAI_API_KEY=

# Slack webhook for system alerts (optional)
SLACK_WEBHOOK_URL=

# ── Monitoring ────────────────────────────────────────────────────────────────
# Optional token to protect the Prometheus scrape endpoint /api/health/prometheus
# Leave empty to allow unauthenticated scraping (fine for internal-only deployments)
PROMETHEUS_SCRAPE_TOKEN=

# ── CORS / Trusted Origins ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (in addition to defaults)
# EXTRA_CORS_ORIGINS=https://custom.yourdomain.com
