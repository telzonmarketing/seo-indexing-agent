# ═══════════════════════════════════════════════════════════════════════════════
# SEO OS — Frontend Environment Variables
# Copy this file to .env.local
# ═══════════════════════════════════════════════════════════════════════════════

# ── API URL ───────────────────────────────────────────────────────────────────
# Local dev: API runs on :8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production (subdomain setup via NGINX — /api/ is proxied from admin domain):
# NEXT_PUBLIC_API_URL=https://admin.telzonmarketing.in
# or direct API subdomain:
# NEXT_PUBLIC_API_URL=https://api.telzonmarketing.in

# Staging:
# NEXT_PUBLIC_API_URL=https://staging.telzonmarketing.in

# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=SEO OS
NEXT_PUBLIC_AGENCY_NAME=Telzon Marketing

# ── Mission Control URL ───────────────────────────────────────────────────────
NEXT_PUBLIC_MISSION_CONTROL_URL=http://localhost:3000/missioncontrol
# Production:
# NEXT_PUBLIC_MISSION_CONTROL_URL=https://missioncontrol.telzonmarketing.in
