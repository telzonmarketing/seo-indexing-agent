# ============================================================
# SEO OS — Environment Configuration
# ============================================================
# For the new full-stack system, see backend/.env.example
# This file is kept for the legacy Node.js CLI tool

# ── SEO OS (new platform) ──────────────────────────────────
# Backend: backend/.env.example → backend/.env
# Frontend: frontend/.env.local.example → frontend/.env.local
# Quick start: make setup-env && make up

# ── Legacy CLI Tool (original) ─────────────────────────────

# --- Google Search Console / Indexing API ---
# Service account JSON key (path to file OR paste JSON inline)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./config/service-account.json
# OR inline JSON:
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Google OAuth (for Search Console API access)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Target Website ---
SITE_URL=https://yourwebsite.com

# --- GitHub Integration (optional) ---
GITHUB_TOKEN=
GITHUB_REPO=owner/repo-name
GITHUB_BRANCH=main

# --- Agent Settings ---
# How deep to crawl (number of pages)
MAX_CRAWL_PAGES=1000
# Delay between requests in ms (be polite to servers)
CRAWL_DELAY_MS=500
# Auto-submit fixed pages to Google Indexing API
AUTO_SUBMIT=true
# How often to run monitor in hours (for --monitor mode)
MONITOR_INTERVAL_HOURS=24

# --- Notifications (optional) ---
SLACK_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=
EMAIL_TO=
